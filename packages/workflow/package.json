{
  "name": "@ziroagent/workflow",
  "version": "0.1.0",
  "description": "Type-safe graph engine for multi-step, multi-agent workflows.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/ziroagent/sdk-typescript/tree/main/packages/workflow",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziroagent/sdk-typescript.git",
    "directory": "packages/workflow"
  },
  "bugs": {
    "url": "https://github.com/ziroagent/sdk-typescript/issues"
  },
  "keywords": [
    "ai",
    "workflow",
    "graph",
    "agent",
    "orchestration",
    "ziroagent"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "publint": "publint",
    "attw": "attw --pack ."
  },
  "dependencies": {
    "@ziroagent/core": "workspace:*"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
