{
  "name": "@ziro-agent/checkpoint-postgres",
  "version": "0.3.15",
  "description": "Production Postgres Checkpointer adapter for ZiroAgent SDK — durable agent state with row-locked snapshot persistence (RFC 0006).",
  "license": "Apache-2.0",
  "homepage": "https://ziroagent.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziroagent/sdk-typescript.git",
    "directory": "packages/checkpoint-postgres"
  },
  "bugs": {
    "url": "https://github.com/ziroagent/sdk-typescript/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "checkpoint",
    "durable",
    "postgres",
    "ziroagent"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "publint": "publint",
    "attw": "attw --pack . --profile=node16"
  },
  "dependencies": {
    "@ziro-agent/agent": "workspace:*"
  },
  "peerDependencies": {
    "pg": ">=8.10.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": false
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/pg": "^8.15.6",
    "pg": "^8.16.4",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "ZiroAgent <hello@ziroagent.com> (https://ziroagent.com)"
}
