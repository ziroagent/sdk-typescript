{
  "name": "@ziro-ai/tools",
  "version": "0.1.0",
  "description": "Type-safe tool definitions, parallel execution, and MCP adapter for Ziro AI SDK.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/ziro-ai/sdk/tree/main/packages/tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziro-ai/sdk.git",
    "directory": "packages/tools"
  },
  "bugs": {
    "url": "https://github.com/ziro-ai/sdk/issues"
  },
  "keywords": [
    "ai",
    "tools",
    "agent",
    "zod",
    "mcp",
    "ziro"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "require": "./dist/mcp/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "publint": "publint",
    "attw": "attw --pack ."
  },
  "dependencies": {
    "@ziro-ai/core": "workspace:*",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
