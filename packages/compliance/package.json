{
  "name": "@ziro-agent/compliance",
  "version": "0.4.0",
  "description": "Compliance helpers — ordered user-data deletion, report JSON, EU AI Act template (RFC 0016).",
  "license": "Apache-2.0",
  "homepage": "https://ziroagent.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziroagent/sdk-typescript.git",
    "directory": "packages/compliance"
  },
  "bugs": {
    "url": "https://github.com/ziroagent/sdk-typescript/issues"
  },
  "keywords": [
    "ai",
    "compliance",
    "gdpr",
    "eu-ai-act",
    "ziroagent"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "publint": "publint",
    "attw": "attw --pack . --profile=node16"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "^22.10.5",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "ZiroAgent <hello@ziroagent.com> (https://ziroagent.com)"
}
