{
  "name": "@ziro-agent/memory",
  "version": "0.5.0",
  "description": "Vector store interfaces, in-memory & pgvector adapters, chunking and embedding helpers for ZiroAgent SDK.",
  "license": "Apache-2.0",
  "homepage": "https://ziroagent.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziroagent/sdk-typescript.git",
    "directory": "packages/memory"
  },
  "bugs": {
    "url": "https://github.com/ziroagent/sdk-typescript/issues"
  },
  "keywords": [
    "ai",
    "memory",
    "rag",
    "vector",
    "pgvector",
    "embeddings",
    "ziroagent",
    "typescript",
    "agent-sdk",
    "ziro-agent"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./pgvector": {
      "import": {
        "types": "./dist/stores/pgvector.d.ts",
        "default": "./dist/stores/pgvector.js"
      },
      "require": {
        "types": "./dist/stores/pgvector.d.cts",
        "default": "./dist/stores/pgvector.cjs"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/node.d.ts",
        "default": "./dist/node.js"
      },
      "require": {
        "types": "./dist/node.d.cts",
        "default": "./dist/node.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "publint": "publint",
    "attw": "attw --pack . --profile=node16"
  },
  "dependencies": {
    "@ziro-agent/core": "workspace:*"
  },
  "peerDependencies": {
    "pg": ">=8.10.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/pg": "^8.15.5",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "publint": "^0.3.18",
    "tesseract.js": "^5.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "ZiroAgent <hello@ziroagent.com> (https://ziroagent.com)"
}
