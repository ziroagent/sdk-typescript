{
  "name": "@ziro-agent/docs",
  "version": "0.1.0",
  "private": true,
  "description": "Documentation site for the ZiroAgent SDK (Fumadocs + Next.js).",
  "type": "module",
  "scripts": {
    "dev": "pnpm run rfc:index && fumadocs-mdx && next dev --port 4001",
    "prebuild": "pnpm run rfc:index && pnpm run api:generate && fumadocs-mdx",
    "build": "next build",
    "start": "next start --port 4001",
    "typecheck": "pnpm run rfc:index && fumadocs-mdx && tsc --noEmit",
    "api:generate": "typedoc",
    "rfc:index": "node ./scripts/generate-rfc-index.mjs"
  },
  "dependencies": {
    "fumadocs-core": "^16.8.4",
    "fumadocs-mdx": "^14.3.1",
    "fumadocs-ui": "^16.8.1",
    "next": "^16.2.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
